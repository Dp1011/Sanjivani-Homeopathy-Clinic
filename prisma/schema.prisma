generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Appointment {
  id              String              @id @default(cuid())
  fullName        String
  email           String
  phone           String
  preferredDate   DateTime
  preferredTime   String
  reason          String?
  status          String              @default("PENDING")
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PatientRecord {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  phone       String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ErrorReport {
  id          String   @id @default(cuid())
  name        String?
  email       String?
  subject     String
  message     String
  pageUrl     String?
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
