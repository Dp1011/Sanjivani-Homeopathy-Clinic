generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DoctorAvailability {
  id        String   @id @default(cuid())
  date      DateTime @unique
  dayOfWeek Int      // 0-6 (Monday=1, Sunday=0)
  isWorking Boolean  @default(true)
  slots     Slot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@map("doctor_availabilities")
}

model Slot {
  id             String   @id @default(cuid())
  availability   DoctorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  availabilityId String
  time           String   // "09:00", "09:30", etc.
  duration       Int      @default(75) // minutes
  isBooked       Boolean  @default(false)
  appointment    Appointment?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([availabilityId, time])
  @@index([isBooked])
  @@map("slots")
}

model Appointment {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  phone           String
  preferredDate   DateTime
  preferredTime   String
  reason          String?
  status          String   @default("CONFIRMED")
  slot            Slot?    @relation(fields: [slotId], references: [id], onDelete: SetNull)
  slotId          String?  @unique
  confirmedAt     DateTime @default(now())
  confirmationNumber String @unique @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("appointments")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PatientRecord {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  phone       String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ErrorReport {
  id          String   @id @default(cuid())
  name        String?
  email       String?
  subject     String
  message     String
  pageUrl     String?
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())
}
