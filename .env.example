# Copy to .env and adjust values.

# SQLite database file (relative to prisma folder)
DATABASE_URL="file:./dev.db"

# Admin dashboard password (change in production)
ADMIN_PASSWORD="change-this-password"

# Used to sign admin session cookie — use a long random string in production
SESSION_SECRET="generate-a-random-32-char-string"

# Clinic contact information
CLINIC_NAME="Sanjivani Homeopathic Clinic"
CLINIC_DOCTOR_NAME="Dr. Yogesh M Patil (MD Homeopathy)"
CLINIC_PHONE="+919420441549"
CLINIC_ADDRESS_STREET="Station Road"
CLINIC_ADDRESS_CITY="Nandurbar"
CLINIC_ADDRESS_STATE="Maharashtra"
CLINIC_HOURS_MON_FRI="09:00 - 18:00"
CLINIC_HOURS_SAT="10:00 - 14:00"

# Error reports are emailed to this address when SMTP is configured below
DOCTOR_EMAIL="doctor@example.com"

# SMTP (e.g. Gmail app password, or your host's outgoing mail)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
# Optional; defaults to SMTP_USER
SMTP_FROM=""

# Appointment booking settings
APPOINTMENT_BOOKING_DAYS_AHEAD="7"
APPOINTMENT_MAX_BOOKING_DAYS="90"

# Pricing information
SERVICE_INITIAL_CONSULTATION_PRICE="₹500"
SERVICE_INITIAL_CONSULTATION_DURATION="75–90 minutes"
SERVICE_FOLLOWUP_PRICE="₹300"
SERVICE_FOLLOWUP_DURATION="30–45 minutes"
SERVICE_ACUTE_PRICE="₹200"
SERVICE_ACUTE_DURATION="15–30 minutes"
SERVICE_FAMILY_CHILDREN_PRICE="₹300"
